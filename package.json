{
  "name": "claude-config-manager",
  "version": "1.0.4",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "bundle": "npm run bundle --workspace=@ccm/mcp",
    "dev": "turbo dev",
    "start": "cd packages/dashboard && npx next start -p 3399",
    "build:dashboard": "turbo build --filter=@ccm/dashboard",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "prepublishOnly": "turbo build",
    "postinstall": "turbo build || true"
  },
  "bin": {
    "claude-config": "./packages/cli/dist/index.js"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "skills": "^1.5.0"
  }
}
